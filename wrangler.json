{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mtasts-motor",
  "main": "src/index.ts",
  "compatibility_date": "2026-04-06",
  "workers_dev": true,
  "observability": {
    "enabled": true,
    "head_sampling_rate": 1,
    "logs": {
      "enabled": true,
      "invocation_logs": true,
      "head_sampling_rate": 1
    }
  },
  "d1_databases": [
    {
      "binding": "BIGDATA_DB",
      "database_name": "bigdata_db",
      "database_id": "00000000-0000-0000-0000-000000000000"
    }
  ]
}
