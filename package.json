  "license": "AGPL-3.0-or-later",
  "author": "Leonardo Cardozo Vargas (lcv-leo)",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lcv-leo/mtasts-motor.git"
  },
  "homepage": "https://github.com/lcv-leo/mtasts-motor#readme",
  "bugs": {
    "url": "https://github.com/lcv-leo/mtasts-motor/issues"
